# Copy this file to ".env" and fill in the key for the provider you use.
# RAGKit loads .env automatically and reads the standard variable names below.

# Groq (llm="groq")
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# OpenAI (llm="openai")
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Google Gemini (llm="google")   -> pip install google-generativeai
# GOOGLE_API_KEY=xxxxxxxxxxxxxxxxxxxx

# Anthropic Claude (llm="anthropic")  -> pip install anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
